{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "preserve",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "types": ["node"],
        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"],
            "ziggy-js": ["vendor/tightenco/ziggy/src/js"]
        },
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": ["resources/js/**/*"],
    "exclude": ["node_modules", "public", "vendor"]
}
